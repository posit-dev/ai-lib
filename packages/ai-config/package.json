{
  "name": "ai-config",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-product AI configuration: schema, validation, merge/resolution, and file load/watch/write for ~/.posit/genai/",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "typescript": "^6.0.2",
    "vitest": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/ai-provider-bridge",
    "directory": "packages/ai-config"
  }
}
