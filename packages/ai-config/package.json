{
  "name": "ai-config",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-product AI configuration: schema, validation, merge/resolution, and file load/watch/write for ~/.posit/ai/",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./positron": {
      "types": "./dist/positron/index.d.ts",
      "import": "./dist/positron/index.js"
    },
    "./providers.schema.json": "./providers.schema.json"
  },
  "scripts": {
    "generate-schema": "tsx scripts/generate-schema.ts",
    "prebuild": "npm run generate-schema",
    "build": "tsc -p .",
    "watch": "tsc -p . --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "vscode": "^1.100.0"
  },
  "peerDependenciesMeta": {
    "vscode": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/proper-lockfile": "^4.1.4",
    "@types/vscode": "^1.100.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/ai-provider-bridge",
    "directory": "packages/ai-config"
  }
}
