{
  "name": "ai-credential-store",
  "version": "0.0.1",
  "private": true,
  "description": "Generic typed key-value secret store on disk with atomic writes, secure permissions, cross-process locking, and file watching",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^6.0.2",
    "vitest": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/ai-provider-bridge",
    "directory": "packages/ai-credential-store"
  }
}
