{
  "name": "ai-credentials",
  "version": "0.0.1",
  "private": true,
  "description": "Credential types, shaping, and generic secret store for Posit AI products",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js"
    },
    "./store-backend": {
      "types": "./dist/store-backend/index.d.ts",
      "import": "./dist/store-backend/index.js"
    },
    "./positron": {
      "types": "./dist/positron/index.d.ts",
      "import": "./dist/positron/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "vscode": "^1.100.0"
  },
  "peerDependenciesMeta": {
    "vscode": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/proper-lockfile": "^4.1.4",
    "@types/vscode": "^1.100.0",
    "typescript": "^7.0.2",
    "vitest": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/posit-dev/ai-provider-bridge",
    "directory": "packages/ai-credentials"
  }
}
